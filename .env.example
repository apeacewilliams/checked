# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Database (required) ───────────────────────────────────────
# Local Postgres (default for development — see README for spin-up options)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/checked"
# Production (Neon pooled connection string — use the -pooler endpoint)
# DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"

# ── Firebase Admin (required) ────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

── Weather API
WEATHER_API_KEY=5e5763c7175b4db792853554242107 

# ── AWS / DynamoDB (optional — falls back to in-memory cache) ─
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# DYNAMODB_TABLE_NAME=weather-cache

# ── Client (client/.env) ──────────────────────────────────────
